# ================================================
# PAWCARE — переменные окружения
# Скопируй: copy .env.example .env
# Затем вставь свои ключи
# ================================================

PORT=3000

# --------------------------------------------------
# ИИ-ПОМОЩНИК — выбери один вариант
# --------------------------------------------------

# ВАРИАНТ 1 (РЕКОМЕНДУЕТСЯ ДЛЯ РОССИИ): OpenRouter
# Работает без VPN, есть БЕСПЛАТНЫЕ модели
# Регистрация: https://openrouter.ai → Sign In → Keys → Create Key
# Бесплатные модели: meta-llama/llama-3.1-8b-instruct:free
#                    mistralai/mistral-7b-instruct:free
# Платные (лучше): openai/gpt-4o, anthropic/claude-3-haiku
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openrouter/auto

# ВАРИАНТ 2: OpenAI (нужен платный аккаунт + VPN для регистрации)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-ваш_ключ_сюда

# ВАРИАНТ 3: Google Gemini (не работает в России без VPN)
# GEMINI_API_KEY=ваш_ключ

# Какой провайдер использовать: openrouter / openai / gemini
AI_PROVIDER=openrouter

# --------------------------------------------------
# ЯНДЕКС КАРТЫ (необязательно — без ключа тоже работает)
# Получить бесплатно: https://developer.tech.yandex.ru
# --------------------------------------------------
YANDEX_MAPS_KEY=ваш_ключ_яндекс

