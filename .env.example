# ================================================
# PAWCARE — переменные окружения
# Скопируй этот файл: copy .env.example .env
# ================================================

PORT=3000

# ================================================================
#  ИИ-ПОМОЩНИК — выбери ОДИН вариант и раскомментируй нужные строки
# ================================================================

# ------------------------------------------------------------------
# ВАРИАНТ 1 ✅ РЕКОМЕНДУЕТСЯ: GigaChat от Сбера
# Бесплатно: 1 000 000 токенов в месяц
# Без VPN, оплата не нужна
# Как получить:
#   1. Зайди на https://developers.sber.ru/studio
#   2. Нажми «Войти» → войди через Сбер ID (или создай аккаунт)
#   3. Создай проект → выбери GigaChat API
#   4. В разделе «Доступ» скопируй «Авторизационные данные»
#      (это длинная строка Base64 — вставь её ниже)
# ------------------------------------------------------------------
GIGACHAT_CREDENTIALS=вставь_строку_из_личного_кабинета_сбера
AI_PROVIDER=gigachat

# ------------------------------------------------------------------
# ВАРИАНТ 2: OpenRouter (тоже без VPN, есть бесплатные модели)
# Регистрация: https://openrouter.ai → Keys → Create Key
# Бесплатные модели: meta-llama/llama-3.1-8b-instruct:free
# ------------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-v1-ваш_ключ
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# AI_PROVIDER=openrouter

# ------------------------------------------------------------------
# ВАРИАНТ 3: OpenAI (нужен платный аккаунт)
# ------------------------------------------------------------------
# OPENAI_API_KEY=sk-ваш_ключ
# AI_PROVIDER=openai

# ================================================================
#  ЯНДЕКС КАРТЫ (необязательно — без ключа тоже работает)
#  Получить бесплатно: https://developer.tech.yandex.ru
# ================================================================
YANDEX_MAPS_KEY=ваш_ключ_яндекс

